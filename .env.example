# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# LLM (小米 MiMo TokenPlan)
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_KEY=your-api-key-here
REVIEWFORGE_MODEL=MiMo

# API 鉴权（非 mock 模式必填）
REVIEWFORGE_API_TOKEN=your-api-token-here

# CORS（逗号分隔的允许来源）
REVIEWFORGE_CORS_ORIGINS=http://localhost:5173

# 插件加载（默认关闭，=1 开启）
REVIEWFORGE_ENABLE_PLUGINS=0

# 并发审查上限
REVIEWFORGE_MAX_CONCURRENT_REVIEWS=3

# Agentic 模式（逗号分隔的 reviewer 名，留空=全部单次）
# REVIEWFORGE_AGENTIC_REVIEWERS=security_reviewer

# Mock 模式（本地测试用）
# REVIEWFORGE_MOCK=1
